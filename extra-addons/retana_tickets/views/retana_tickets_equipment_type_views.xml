<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- View retana.tickets.equipment.type View Tree -->
    <record id="view_retana_tickets_equipment_type_tree" model="ir.ui.view">
        <field name="name">view_retana_tickets_equipment_type_tree</field>
        <field name="model">retana.tickets.equipment.type</field>
        <field name="arch" type="xml">
            <tree string="Tipos de Equipos para Tickets de Soporte">
                <field name="name"/>
            </tree>
        </field>
    </record>

    <!-- View retana.tickets.equipment.type form -->
    <record id="view_retana_tickets_equipment_type_form" model="ir.ui.view">
        <field name="name">view_retana_tickets_equipment_type_form</field>
        <field name="model">retana.tickets.equipment.type</field>
        <field name="arch" type="xml">
            <form string="Tipo de Equipo para Tickets de Soporte">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Nombre..."/>
                        </h1>
                    </div>
                </sheet>
                <!-- Chatter -->
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

    <!-- View retana.tickets.equipment.type search -->
    <record id="view_retana_tickets_equipment_type_search" model="ir.ui.view">
        <field name="name">view.retana.tickets.equipment.type.search</field>
        <field name="model">retana.tickets.equipment.type</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" string="Nombre del Tipo de Equipo"/>
            </search>
        </field>
    </record>

    <!-- Action retana.tickets.equipment.type -->
    <record id="action_retana_tickets_equipment_type" model="ir.actions.act_window">
        <field name="name">Tipo de Equipo para Tickets de Soporte</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">retana.tickets.equipment.type</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[]</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                No hay ejemplos, haga clic aquí para agregar un nuevo Tipo de Equipo para Tickets de Soporte.
            </p>
        </field>
    </record>

    <menuitem id="menu_retana_tickets_equipment_type" name="Tipos de Equipos para Tickets de Soporte" parent="menu_retana_tickets_equipment_root" action="action_retana_tickets_equipment_type" sequence="20"/>

</odoo>
