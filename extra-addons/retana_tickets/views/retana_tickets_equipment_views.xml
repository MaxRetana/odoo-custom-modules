<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- View retana.tickets.equipment View Tree -->
    <record id="view_retana_tickets_equipment_tree" model="ir.ui.view">
        <field name="name">view_retana_tickets_equipment_tree</field>
        <field name="model">retana.tickets.equipment</field>
        <field name="arch" type="xml">
            <tree string="Equipos de Trabajo">
                <field name="name"/>
                <field name="code"/>
                <field name="equipment_type_id"/>
                <field name="equipment_brand_id"/>
                <field name="user_assigned_id"/>
                <field name="date_purchase"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <!-- View retana.tickets.equipment form -->
    <record id="view_retana_tickets_equipment_form" model="ir.ui.view">
        <field name="name">view_retana_tickets_equipment_form</field>
        <field name="model">retana.tickets.equipment</field>
        <field name="arch" type="xml">
            <form string="Equipo de Trabajo">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Nombre..."/>
                        </h1>
                    </div>
                    <group>
                        <field name="equipment_brand_id"/>
                        <field name="code"/>
                        <field name="equipment_type_id"/>
                        <field name="user_assigned_id"/>
                        <field name="date_purchase"/>
                        <field name="state"/>
                    </group>
                </sheet>
                <!-- Chatter -->
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

    <!-- View retana.tickets.equipment search -->
    <record id="view_retana_tickets_equipment_search" model="ir.ui.view">
        <field name="name">view_retana_tickets_equipment_search</field>
        <field name="model">retana.tickets.equipment</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" string="Nombre del Equipo"/>
                <field name="code" string="Código del Equipo"/>
                <field name="date_purchase" string="Fecha de Compra"/>
                <group expand="1" string="Group By">
                    <filter string="Tipo de Equipo" name="equipment_type_id" domain="[]" context="{'group_by':'equipment_type_id'}"/>
                    <filter string="Usuario Asignado" name="user_assigned_id" domain="[]" context="{'group_by':'user_assigned_id'}"/>
                    <filter string="Estado" name="state" domain="[]" context="{'group_by':'state'}"/>
                    <filter string="Marca del equipo" name="equipment_brand_id" domain="[]" context="{'group_by':'equipment_brand_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action retana.tickets.equipment -->
    <record id="action_retana_tickets_equipment" model="ir.actions.act_window">
        <field name="name">Equipos de Trabajo</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">retana.tickets.equipment</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[]</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                No hay ejemplos, haga clic aquí para agregar un nuevo Equipo de Trabajo.
            </p>
        </field>
    </record>

    <!-- Menuitem retana.tickets.equipment -->
    <menuitem id="menu_retana_tickets_equipment_root" name="Equipos de Trabajo" parent="retana_tickets_menu_configuration" sequence="100"/>

    <menuitem id="menu_retana_tickets_equipment" name="Equipos de Trabajo" parent="menu_retana_tickets_equipment_root" action="action_retana_tickets_equipment" sequence="10"/>

</odoo>
