<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- View retana.tickets View Tree -->
    <record id="view_retana_tickets_tree" model="ir.ui.view">
        <field name="name">view_retana_tickets_tree</field>
        <field name="model">retana.tickets</field>
        <field name="arch" type="xml">
            <tree string="Retana Tickets" 
                  decoration-info="state == 'draft'" 
                  decoration-warning="state == 'in_revision'" 
                  decoration-primary="state == 'in_progress'"
                  decoration-success="state == 'resolved'"
                  decoration-muted="state == 'cancel'"
                  decoration-danger="priority == 'critical'">
                <field name="name" string="Ticket Nº"/>
                <field name="priority" widget="priority"/>
                <field name="equipment_id"/>
                <field name="user_reported_id" widget="many2one_avatar_user"/>
                <field name="user_assigned_id" widget="many2one_avatar_user"/>
                <field name="description"/>
                <field name="state" widget="badge" decoration-info="state == 'draft'" 
                       decoration-warning="state == 'in_revision'" 
                       decoration-primary="state == 'in_progress'"
                       decoration-success="state == 'resolved'"
                       decoration-muted="state == 'cancel'"/>
            </tree>
        </field>
    </record>

    <!-- View retana.tickets form -->
    <record id="view_retana_tickets_form" model="ir.ui.view">
        <field name="name">view_retana_tickets_form</field>
        <field name="model">retana.tickets</field>
        <field name="arch" type="xml">
            <form string="Retana Ticket">
                <header>
                    <field name="state" widget="statusbar" options="{'clickable': '1'}"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <field name="priority" widget="priority"/>
                    </div>
                    <div class="oe_title">
                        <label for="name" string="Ticket Nº"/>
                        <h1>
                            <field name="name" placeholder="Número de Ticket..." readonly="1" force_save="1"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Información del Ticket">
                            <field name="equipment_id" options="{'no_create': True}"/>
                            <field name="user_reported_id" options="{'no_create': True}"/>
                        </group>
                        <group string="Asignación y Seguimiento">
                            <field name="user_assigned_id" options="{'no_create': True}"/>
                        </group>
                    </group>
                    <group string="Descripción del Problema">
                        <field name="description" nolabel="1" placeholder="Describa el problema con el mayor detalle posible..."/>
                    </group>
                </sheet>
                <!-- Chatter -->
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

    <!-- View retana.tickets search -->
    <record id="view_retana_tickets_search" model="ir.ui.view">
        <field name="name">view_retana_tickets_search</field>
        <field name="model">retana.tickets</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" string="Nombre del Ticket"/>
                <field name="description" string="Descripción del Ticket"/>
                <field name="user_reported_id" string="Usuario que Reporta"/>
                <field name="user_assigned_id" string="Usuario Asignado"/>
                <group expand="1" string="Group By">
                    <filter string="Estado" name="state" domain="[]" context="{'group_by':'state'}"/>
                    <filter string="Prioridad" name="priority" domain="[]" context="{'group_by':'priority'}"/>
                    <filter string="Usuario Asignado" name="user_assigned_id" domain="[]" context="{'group_by':'user_assigned_id'}"/>
                    <filter string="Usuario que Reporta" name="user_reported_id" domain="[]" context="{'group_by':'user_reported_id'}"/>
                    <filter string="Equipo" name="equipment_id" domain="[]" context="{'group_by':'equipment_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- View retana.tickets kanban -->
    <record id="view_retana_tickets_kanban" model="ir.ui.view">
        <field name="name">view_retana_tickets_kanban</field>
        <field name="model">retana.tickets</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column">
                <field name="name"/>
                <field name="state"/>
                <field name="priority"/>
                <field name="equipment_id"/>
                <field name="user_reported_id"/>
                <field name="user_assigned_id"/>
                <field name="description"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_card oe_kanban_global_click">
                            <div class="oe_kanban_content">
                                <div class="o_kanban_record_top">
                                    <div class="o_kanban_record_headings">
                                        <strong class="o_kanban_record_title">
                                            <field name="name"/>
                                        </strong>
                                    </div>
                                    <div class="o_kanban_record_top_right">
                                        <field name="priority" widget="priority"/>
                                    </div>
                                </div>
                                <div class="o_kanban_record_body">
                                    <field name="equipment_id" widget="many2one_avatar_user"/>
                                    <div class="text-muted" t-if="record.description.value">
                                        <t t-esc="record.description.value.substr(0, 80)"/>
                                        <t t-if="record.description.value.length > 80">...</t>
                                    </div>
                                </div>
                                <div class="o_kanban_record_bottom">
                                    <div class="oe_kanban_bottom_left">
                                        <span t-if="record.user_reported_id.value" class="text-muted">
                                            <i class="fa fa-user-o"/> <field name="user_reported_id"/>
                                        </span>
                                    </div>
                                    <div class="oe_kanban_bottom_right">
                                        <field name="user_assigned_id" widget="many2one_avatar_user"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Action retana.tickets -->
    <record id="action_retana_tickets" model="ir.actions.act_window">
        <field name="name">Retana Tickets</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">retana.tickets</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="domain">[]</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                No hay ejemplos, haga clic aquí para agregar un nuevo Ticket de Soporte.
            </p>
        </field>
    </record>

    <!-- Barra de menus -->

    <menuitem
        id="retana_tickets_menu_root"
        name="Retana Tickets"
        sequence="10"/>

    <!-- Configuracion -->
    <menuitem
        id="retana_tickets_menu_configuration"
        name="Configuración"
        parent="retana_tickets_menu_root"
        sequence="100"
        groups="retana_tickets.group_retana_tickets_admin"/>

    <menuitem
        id="retana_tickets_menu"
        name="Tickets de Soporte"
        parent="retana_tickets_menu_root"
        action="action_retana_tickets"
        groups="retana_tickets.group_retana_tickets_admin,retana_tickets.group_retana_tickets_user"/>

    

</odoo>
